# ==========================================
# LuxeMart - Environment Variables Template
# ==========================================

# 1. Backend Configuration (Save as backend/.env)
# -----------------------------------------------
NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://localhost:27017/luxemart

# JWT Authentication
# Replace this with a strong, random string in production
JWT_SECRET=luxemart_super_secret_jwt_key_2024_premium
JWT_EXPIRE=30d

# 2. Frontend Configuration (Save as frontend/.env - Optional)
# ------------------------------------------------------------
# The frontend uses Vite's proxy in development to route /api to localhost:5000
# But you can define explicit variables here if needed for deployment
VITE_API_URL=/api
